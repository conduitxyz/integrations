{
  "name": "@conduitxyz/integrations",
  "version": "1.1.0",
  "description": "SDK for Conduit Integrations",
  "keywords": [],
  "homepage": "https://github.com/conduitxyz/integrations#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/conduitxyz/integrations.git"
  },
  "license": "MIT",
  "author": "Conduit XYZ Inc.",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "del-cli dist && tsc",
    "check-package": "pnpm run build && publint --strict && attw --pack . --profile esm-only",
    "lint": "oxlint",
    "release": "pnpm run build && pnpm changeset publish",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@changesets/cli": "^2.31.0",
    "@total-typescript/tsconfig": "^1.0.4",
    "del-cli": "^7.0.0",
    "oxlint": "^1.73.0",
    "publint": "^0.3.21",
    "typescript": "^7.0.2"
  },
  "packageManager": "pnpm@10.33.2",
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
